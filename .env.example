# Transport: stdio | http
MCP_TRANSPORT=http
MCP_SERVER_NAME=mcp-node-framework-starter
MCP_SERVER_VERSION=0.1.0

# HTTP transport
HTTP_HOST=127.0.0.1
HTTP_PORT=3000
HTTP_PATH=/mcp

# Logging: trace | debug | info | warn | error | fatal
LOG_LEVEL=info

# Demo REST API. For a local/internal API, change this URL.
API_BASE_URL=https://httpbin.org
API_TIMEOUT_MS=10000

# none | bearer-env | api-key-env
API_AUTH_TYPE=bearer-env
API_TOKEN=
API_KEY_HEADER=x-api-key
API_KEY=


API_BASE_URL=https://www.juliomorales.dev/restapi/
API_AUTH_TYPE=bearer-env
API_TOKEN=

MCP_AUTH_ENABLED=true
MCP_AUTH_TOKEN=