{
  "name": "miron-mcp",
  "version": "0.1.0",
  "description": "Enterprise-grade framework for building production-ready MCP servers in Node.js.",
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=22.0.0"
  },
  "bin": {
    "mcp-fw": "./tools/mcp-validate.mjs"
  },
  "scripts": {
    "check": "npm run lint && npm run typecheck",
    "predev:stdio": "npm run check",
    "dev:stdio": "tsx watch src/index.ts --transport stdio",
    "dev:inspector": "npm run build && npx -y @modelcontextprotocol/inspector@latest",
    "predev:http": "npm run check",
    "dev:http": "tsx watch src/index.ts --transport http",
    "build": "tsc -p tsconfig.json",
    "start:stdio": "node dist/index.js --transport stdio",
    "start:http": "node dist/index.js --transport http",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "secrets:check": "secretlint \"**/*\"",
    "knip": "knip",
    "audit": "npm audit --audit-level=high",
    "mcp:validate": "node tools/mcp-validate.mjs src",
    "mcp:inspect:stdio": "npx @modelcontextprotocol/inspector node dist/index.js --transport stdio",
    "mcp:inspect:http": "npx @modelcontextprotocol/inspector",
    "commitlint": "commitlint",
    "lint-staged": "lint-staged",
    "validate": "npm run mcp:validate && npm run typecheck && npm run lint && npm run format:check && npm run test && npm run secrets:check",
    "prepare": "husky"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "dotenv": "^16.4.7",
    "express": "^4.19.2",
    "js-yaml": "^4.1.0",
    "pino": "^9.6.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.6.1",
    "@commitlint/config-conventional": "^19.6.0",
    "@eslint/js": "^9.17.0",
    "@secretlint/secretlint-rule-preset-recommend": "^9.0.0",
    "@types/express": "^4.17.21",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.10.2",
    "@vitest/coverage-v8": "^2.1.8",
    "eslint": "^9.17.0",
    "husky": "^9.1.7",
    "knip": "^5.41.1",
    "lint-staged": "^15.2.11",
    "prettier": "^3.4.2",
    "secretlint": "^9.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.2",
    "vitest": "^2.1.8"
  },
  "lint-staged": {
    "*.{ts,js,mjs}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  }
}
